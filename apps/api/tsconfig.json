{
  "extends": "@customer-reg/tsconfig/nestjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@customers/*": ["src/customers/*"],
      "@colors/*": ["src/colors/*"],
      "@database/*": ["src/database/*"],
      "@health/*": ["src/health/*"]
